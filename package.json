{
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter @lavaanime/shared build && pnpm --filter @lavaanime/web build & pnpm --filter @lavaanime/server build & wait",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm --filter @lavaanime/server start",
    "test": "pnpm --filter @lavaanime/server test",
    "test:full": "bash scripts/test-full.sh",
    "sync": "pnpm --filter @lavaanime/server sync",
    "db:generate": "pnpm --filter @lavaanime/server db:generate",
    "db:push": "pnpm --filter @lavaanime/server db:push",
    "db:migrate": "pnpm --filter @lavaanime/server db:migrate"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
