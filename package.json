{
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @lavaanime/server dev",
    "dev:web": "pnpm --filter @lavaanime/web dev",
    "build": "pnpm --filter @lavaanime/shared build && pnpm --filter @lavaanime/server build",
    "build:web": "pnpm --filter @lavaanime/web build",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm --filter @lavaanime/server start",
    "test": "pnpm --filter @lavaanime/server test",
    "test:watch": "pnpm --filter @lavaanime/server test:watch",
    "sync": "pnpm --filter @lavaanime/server sync",
    "db:generate": "pnpm --filter @lavaanime/server db:generate",
    "db:push": "pnpm --filter @lavaanime/server db:push",
    "db:migrate": "pnpm --filter @lavaanime/server db:migrate"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
